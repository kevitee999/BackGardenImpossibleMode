-- Ultra-light Seed Tracker - Maximum Performance
local Players = game:GetService("Players")
local player = Players.LocalPlayer

-- Minimal GUI creation
local gui = Instance.new("ScreenGui")
gui.Name = "SeedGUI"
gui.ResetOnSpawn = false
gui.Parent = player:WaitForChild("PlayerGui")

-- Simple frame
local frame = Instance.new("Frame")
frame.Size = UDim2.new(0, 200, 0, 70)  -- Smaller size
frame.Position = UDim2.new(0, 10, 0.5, -35)
frame.BackgroundColor3 = Color3.fromRGB(0, 255, 0)
frame.BorderSizePixel = 3
frame.BorderColor3 = Color3.fromRGB(0, 0, 0)
frame.Active = true
frame.Draggable = true
frame.Parent = gui

-- Seeds text
local seedsText = Instance.new("TextLabel")
seedsText.Size = UDim2.new(1, -10, 0, 30)
seedsText.Position = UDim2.new(0, 5, 0, 5)
seedsText.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
seedsText.TextColor3 = Color3.fromRGB(0, 255, 0)
seedsText.Text = "Seeds: 0"
seedsText.TextSize = 20
seedsText.Font = Enum.Font.GothamBold
seedsText.BorderSizePixel = 2
seedsText.BorderColor3 = Color3.fromRGB(0, 255, 0)
seedsText.Parent = frame

-- Timer text
local timerText = Instance.new("TextLabel")
timerText.Size = UDim2.new(1, -10, 0, 25)
timerText.Position = UDim2.new(0, 5, 0, 38)
timerText.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
timerText.TextColor3 = Color3.fromRGB(0, 255, 0)
timerText.Text = "00:00"
timerText.TextSize = 16
timerText.Font = Enum.Font.Gotham
timerText.BorderSizePixel = 2
timerText.BorderColor3 = Color3.fromRGB(0, 255, 0)
timerText.Parent = frame

-- Hide button
local hideBtn = Instance.new("TextButton")
hideBtn.Size = UDim2.new(0, 20, 0, 20)
hideBtn.Position = UDim2.new(1, -25, 0, 5)
hideBtn.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
hideBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
hideBtn.Text = "−"
hideBtn.TextSize = 16
hideBtn.BorderSizePixel = 2
hideBtn.BorderColor3 = Color3.fromRGB(0, 255, 0)
hideBtn.Parent = frame

-- Variables
local startTime = os.clock()
local hidden = false

-- Get seeds value once
local seedsValue = player:WaitForChild("leaderstats"):WaitForChild("Seeds")

-- Update functions
local function updateDisplay()
    seedsText.Text = "Seeds: " .. seedsValue.Value
    local elapsed = math.floor(os.clock() - startTime)
    local mins = math.floor(elapsed / 60)
    local secs = elapsed % 60
    timerText.Text = string.format("%02d:%02d", mins, secs)
end

-- Initial update
updateDisplay()

-- Simple loop - updates everything together
task.spawn(function()
    while gui and gui.Parent do
        updateDisplay()
        task.wait(1)  -- Update everything every second
    end
end)

-- Hide button
hideBtn.MouseButton1Click:Connect(function()
    hidden = not hidden
    frame.BackgroundTransparency = hidden and 1 or 0
    hideBtn.Text = hidden and "□" or "−"
end)
